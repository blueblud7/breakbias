# ==========================================================
# Market Sentiment Radar — 환경변수 예시
# 실제 값은 .env 파일에 넣고, .env 는 절대 커밋하지 말 것.
# ==========================================================

# --- 국내 뉴스/블로그: Naver 검색 API ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 해외 뉴스: NewsAPI (https://newsapi.org) ---
NEWSAPI_KEY=

# --- LLM: 개별 분류 (gpt-5-nano) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# --- LLM: 일별 총평 (deepseek-v4-pro, OpenAI 호환) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# --- 유튜브 ---
YOUTUBE_API_KEY=

# --- Reddit ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=market-sentiment-radar/0.1 by u/yourname

# --- (선택) 텔레그램 알림 봇 (M5) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 운영 ---
DB_PATH=data/sentiment.db
DAILY_LLM_BUDGET_USD=2.0
LOG_LEVEL=INFO
